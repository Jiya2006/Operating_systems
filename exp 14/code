#!/bin/bash

echo "Enter number:"
read n

for ((i=2; i*i<=n; i++))
do
    if (( n % i == 0 ))
    then
        echo "Not Prime"
        exit
    fi
done

echo "Prime"



!/bin/bash

echo "Enter a number:"
read n

fact=1

for ((i=1; i<=n; i++))
do
    fact=$((fact * i))
done

echo "Factorial of $n is: $fact"
