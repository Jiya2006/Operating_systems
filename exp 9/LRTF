#include <stdio.h>
#include <limits.h>

int main() {
    int n, i, time = 0, completed = 0;
    
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[n], bt[n], rt[n], wt[n], tat[n];

    // Input Arrival Time and Burst Time
    for(i = 0; i < n; i++) {
        printf("P%d Arrival Time: ", i+1);
        scanf("%d", &at[i]);

        printf("P%d Burst Time: ", i+1);
        scanf("%d", &bt[i]);

        rt[i] = bt[i]; // remaining time
    }

    int max_index;

    // LRTF Scheduling
    while(completed != n) {
        int max = -1;
        max_index = -1;

        // Find process with maximum remaining time
        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0) {
                if(rt[i] > max) {
                    max = rt[i];
                    max_index = i;
                }
            }
        }

        if(max_index == -1) {
            time++;
            continue;
        }

        // Execute process for 1 unit
        rt[max_index]--;
        time++;

        // If process completes
        if(rt[max_index] == 0) {
            completed++;
            int finish_time = time;

            wt[max_index] = finish_time - bt[max_index] - at[max_index];
            if(wt[max_index] < 0)
                wt[max_index] = 0;

            tat[max_index] = bt[max_index] + wt[max_index];
        }
    }

    // Display Results
    printf("\nProcess\tAT\tBT\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\n", i+1, at[i], bt[i], wt[i], tat[i]);
    }

    return 0;
}
